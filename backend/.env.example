# Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# ── Server Configuration ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Connection ────────────────────────────────────────────────────
# Option A: Local MongoDB (default for development)
MONGODB_URI=mongodb://localhost:27017/certchain

# Option B: MongoDB Atlas (cloud — recommended for production)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name (used inside Mongoose connect call)
DB_NAME=certchain

# ── Frontend URL ──────────────────────────────────────────────────────────
# Used by the CORS config to allow requests from the deployed frontend
FRONTEND_URL=http://localhost:5173

# ── Smart Contract (set in Phase 2 after deployment) ─────────────────────
# The deployed address of CertificateRegistry.sol on your testnet
CONTRACT_ADDRESS=
