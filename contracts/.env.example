# Smart Contract Environment Variables
# Copy this file to .env and fill in your values.

# ── Testnet RPC URL ───────────────────────────────────────────────────────
# Get from Infura (https://infura.io) or Alchemy (https://alchemy.com)
# Format: https://sepolia.infura.io/v3/YOUR_PROJECT_ID
SEPOLIA_RPC_URL=

# ── Deployer Wallet Private Key ───────────────────────────────────────────
# Export from MetaMask: Account Details → Export Private Key
# WARNING: NEVER commit this value. Add .env to your .gitignore.
PRIVATE_KEY=

# ── Etherscan API Key ─────────────────────────────────────────────────────
# Get from https://etherscan.io/myapikey (free account)
# Used by: npx hardhat verify --network sepolia <contract_address>
ETHERSCAN_API_KEY=

# ── Gas Reporter ──────────────────────────────────────────────────────────
# Set to 'true' to see gas costs in test output
REPORT_GAS=false
